PORT=3001
NODE_ENV=development

# Same project as the app root .env (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Secret (lets the API verify tokens when Auth is briefly unreachable)
SUPABASE_JWT_SECRET=your-jwt-secret

# Default country calling code when users omit "+" (E.164). Example Nigeria: +234
AUTH_DEFAULT_COUNTRY_CODE=+234

# * allows any origin; for production prefer your Vercel URL(s), comma-separated:
# CORS_ORIGIN=https://chat-reel.vercel.app,http://localhost:8081
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# LiveKit (calls). Sign up at https://cloud.livekit.io and grab a project
# API key + secret. The backend mints short-lived JWTs that the React Native
# client uses to join a Room. The client never sees the secret.
# Leave LIVEKIT_API_KEY blank to disable calling — endpoints will return 503.
# ---------------------------------------------------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# wss://<your-project>.livekit.cloud
LIVEKIT_URL=
# Token TTL in seconds (default 4h). Long enough to outlive a single call.
LIVEKIT_TOKEN_TTL=14400

# ---------------------------------------------------------------------------
# Media CDN + HLS (Phase 2)
# MEDIA_CDN_BASE_URL: CDN in front of ALL Supabase storage (chat-files, avatars, reels).
#   Point Cloudflare (or similar) at your Supabase storage host; keep pathnames.
# REELS_CDN_URL: legacy reels-only CDN; used if MEDIA_CDN_BASE_URL is empty.
# REELS_HLS_ENABLED: transcode uploaded MP4s to HLS segments (requires ffmpeg)
# ---------------------------------------------------------------------------
MEDIA_CDN_BASE_URL=
REELS_CDN_URL=
REELS_HLS_ENABLED=false

# ---------------------------------------------------------------------------
# Phase 2 — scale knobs
# MAX_CONCURRENT_CALLS: joined+held sessions per user before 429
# MESSAGE_ARCHIVE_AFTER_DAYS: move settled messages to messages_archive (0 = off)
# MESSAGE_ARCHIVE_INTERVAL_MS: how often the archive job runs (0 = disable scheduler)
# MESSAGES_LIST_MAX_LIMIT: clamp for GET /api/messages
# ---------------------------------------------------------------------------
MAX_CONCURRENT_CALLS=2
MESSAGE_ARCHIVE_AFTER_DAYS=90
MESSAGE_ARCHIVE_INTERVAL_MS=21600000
MESSAGES_LIST_MAX_LIMIT=100

# ---------------------------------------------------------------------------
# Media lifecycle — recovery + cleanup schedulers (single API instance)
# REEL_RECONCILE_INTERVAL_MS: requeue reels stuck in pending/processing
#   transcode/moderation after a restart (0 = disable, default 10 min)
# REEL_RECONCILE_STALE_MINUTES: how old a stuck row must be before retry (min 10)
# MOMENT_CLEANUP_INTERVAL_MS: purge moments expired >24h ago and release their
#   storage objects (0 = disable, default 6h)
# ---------------------------------------------------------------------------
REEL_RECONCILE_INTERVAL_MS=600000
REEL_RECONCILE_STALE_MINUTES=30
MOMENT_CLEANUP_INTERVAL_MS=21600000

# ---------------------------------------------------------------------------
# Phase 3 — sockets, queues, E2E policy, region label
# REDIS_URL: optional shared job queue (npm i ioredis). Memory queue if unset.
# WS_PATH: WebSocket path on the same HTTP server (default /ws)
# E2E_MODE: off | prefer | strict (strict rejects plaintext text sends)
# REGION_ID: label for this API instance (multi-region ops prep)
# SLO_* : budgets for metrics /alerts (ms)
# ---------------------------------------------------------------------------
REDIS_URL=
WS_PATH=/ws
E2E_MODE=prefer
REGION_ID=default
SLO_SEND_P95_MS=800
SLO_CALL_JOIN_P95_MS=2500

# ---------------------------------------------------------------------------
# Reel content moderation (Sightengine) — https://sightengine.com
# Leave blank to auto-approve all uploads (dev only).
# ---------------------------------------------------------------------------
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
REEL_MODERATION_ENABLED=true
REEL_MODERATION_REJECT_THRESHOLD=0.55
REEL_MODERATION_FLAG_THRESHOLD=0.35

# ---------------------------------------------------------------------------
# Paystack (coin purchases + creator cash-out transfers) — https://paystack.com/docs
# Test keys from Dashboard → Settings → API Keys & Webhooks
# Currency is set per country in coin_packages / payout_thresholds — not here.
# Webhook URL: https://your-api.example.com/api/wallet/paystack/webhook
#   Enable: charge.success, transfer.success, transfer.failed, transfer.reversed
# Callback URL: your web app URL (Paystack redirects here after payment)
# Transfers debit your Paystack balance (fund it in Dashboard → Balance).
# ---------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=

# ---------------------------------------------------------------------------
# Expo push (optional). Improves deliverability / rate limits for Expo Push API.
# Create at https://expo.dev → Account settings → Access tokens
# ---------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=
