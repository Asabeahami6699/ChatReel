PORT=3001
NODE_ENV=development

# Same project as the app root .env (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Secret (lets the API verify tokens when Auth is briefly unreachable)
SUPABASE_JWT_SECRET=your-jwt-secret

# * allows any origin; for production prefer your Vercel URL(s), comma-separated:
# CORS_ORIGIN=https://chat-reel.vercel.app,http://localhost:8081
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# LiveKit (calls). Sign up at https://cloud.livekit.io and grab a project
# API key + secret. The backend mints short-lived JWTs that the React Native
# client uses to join a Room. The client never sees the secret.
# Leave LIVEKIT_API_KEY blank to disable calling — endpoints will return 503.
# ---------------------------------------------------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# wss://<your-project>.livekit.cloud
LIVEKIT_URL=
# Token TTL in seconds (default 4h). Long enough to outlive a single call.
LIVEKIT_TOKEN_TTL=14400

# ---------------------------------------------------------------------------
# Reels CDN + HLS (optional)
# REELS_CDN_URL: custom CDN origin in front of Supabase storage (Cloudflare, etc.)
# REELS_HLS_ENABLED: transcode uploaded MP4s to HLS segments (requires ffmpeg)
# ---------------------------------------------------------------------------
REELS_CDN_URL=
REELS_HLS_ENABLED=false

# ---------------------------------------------------------------------------
# Reel content moderation (Sightengine) — https://sightengine.com
# Leave blank to auto-approve all uploads (dev only).
# ---------------------------------------------------------------------------
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
REEL_MODERATION_ENABLED=true
REEL_MODERATION_REJECT_THRESHOLD=0.55
REEL_MODERATION_FLAG_THRESHOLD=0.35

# ---------------------------------------------------------------------------
# Paystack (coin purchases + creator cash-out transfers) — https://paystack.com/docs
# Test keys from Dashboard → Settings → API Keys & Webhooks
# Currency is set per country in coin_packages / payout_thresholds — not here.
# Webhook URL: https://your-api.example.com/api/wallet/paystack/webhook
#   Enable: charge.success, transfer.success, transfer.failed, transfer.reversed
# Callback URL: your web app URL (Paystack redirects here after payment)
# Transfers debit your Paystack balance (fund it in Dashboard → Balance).
# ---------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=
