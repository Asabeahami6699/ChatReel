# Frontend environment (React Native / Expo)
# Copy to .env at the project root (same folder as app.config.js), then restart Expo.
# Values are read in app.config.js and exposed via expo.extra so web and native both work.

EXPO_PUBLIC_API_URL=http://localhost:3002
EXPO_PUBLIC_WEB_URL=https://chat-reel.vercel.app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Physical Android over Wi-Fi: keep localhost above; start with `npm start` (--lan).
# If auto-detection fails, set your PC's LAN IP (same one Metro shows in the QR URL):
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.5
# USB + adb reverse instead of Wi-Fi:
# EXPO_PUBLIC_DEV_USE_ADB_REVERSE=true

# Optional: required for Expo push tokens in production builds
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Default country calling code for phone auth when users omit "+"
EXPO_PUBLIC_DEFAULT_COUNTRY_CODE=+234

# Legacy fallbacks (also read by src/lib/config.ts if EXPO_PUBLIC_* unset)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
